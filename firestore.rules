rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entity Validations ---

    function isValidItem(data) {
      return data.keys().hasAll(['id', 'name', 'boxPrice', 'loosePrice', 'defaultType', 'userId']) 
        && data.keys().size() <= 7 // Allow optional updatedAt
        && data.id is string && data.id.size() <= 128
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.boxPrice is number && data.boxPrice >= 0
        && data.loosePrice is number && data.loosePrice >= 0
        && data.defaultType in ['box', 'loose']
        && data.userId == request.auth.uid
        && (data.get('updatedAt', null) == null || data.updatedAt == request.time);
    }

    // --- Match Blocks ---

    match /items/{itemId} {
      allow get: if isOwner(existing().userId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn() 
        && isValidId(itemId) 
        && isValidItem(incoming())
        && itemId == incoming().id;

      allow update: if isOwner(existing().userId)
        && isValidItem(incoming())
        && incoming().id == existing().id // Immutable ID
        && incoming().userId == existing().userId // Immutable Owner
        && incoming().diff(existing()).affectedKeys().hasAny(['name', 'boxPrice', 'loosePrice', 'defaultType', 'updatedAt']);

      allow delete: if isOwner(existing().userId);
    }
  }
}
